const WheatStrawArtPage = () => {
  const [loading, setLoading] = useState(true);
  const [activeCategory, setActiveCategory] = useState<string>("动物系列");
  const [viewedImages, setViewedImages] = useState<string[]>([]);
  const [currentImageIndex, setCurrentImageIndex] = useState(0);
  const [showModal, setShowModal] = useState(false);
  const [hoveredImage, setHoveredImage] = useState<string | null>(null);
  const [showInfo, setShowInfo] = useState(false);
  const [isImageEnlarged, setIsImageEnlarged] = useState(false);
  const [enlargedImageSrc, setEnlargedImageSrc] = useState<string | null>(null);
  const [selectedArtwork, setSelectedArtwork] = useState(wheatStrawArtworks[0]);
  const [showProductModal, setShowProductModal] = useState(false);
  const [isDropdownOpen, setIsDropdownOpen] = useState(false);
  const [hoveredImageIndex, setHoveredImageIndex] = useState<number | null>(null);

  const { addToCart } = useCart();
  const sectionRefs = useRef<(HTMLDivElement | null)[]>([]);
  const heroRef = useRef<HTMLDivElement>(null);
  const mainContentRef = useRef<HTMLDivElement>(null);
  const headerRef = useRef<HTMLDivElement>(null);

  // 模拟加载过程
  useEffect(() => {
    const timer = setTimeout(() => {
      setLoading(false);
    }, 1000);
    return () => clearTimeout(timer);
  }, []);

  // 处理分类点击
  const handleCategoryClick = (categoryName: string) => {
    setActiveCategory(categoryName);
  };

  // 处理图片点击，显示详情
  const handleImageClick = (imageSrc: string, index: number) => {
    setCurrentImageIndex(index);
    setShowModal(true);
    
    // 如果图片不在已查看列表中，添加进去
    if (!viewedImages.includes(imageSrc)) {
      setViewedImages(prev => [...prev, imageSrc]);
    }
  };

  // 关闭图片详情模态框
  const closeModal = () => {
    setShowModal(false);
  };

  // 处理产品点击，显示产品详情
  const handleArtworkClick = (artwork: typeof wheatStrawArtworks[0]) => {
    setSelectedArtwork(artwork);
    setShowProductModal(true);
  };

  // 关闭产品详情模态框
  const closeProductModal = () => {
    setShowProductModal(false);
  };

  // 处理添加到购物车
  const handleAddToCart = () => {
    addToCart(selectedArtwork);
    // 可以在这里添加一个提示，说明商品已添加到购物车
  };

  // 滚动动画效果
  useEffect(() => {
    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            entry.target.classList.add("animate-fade-in");
          }
        });
      },
      { threshold: 0.1 }
    );

    const elements = document.querySelectorAll(".animate-on-scroll");
    elements.forEach((element) => observer.observe(element));

    return () => elements.forEach((element) => observer.unobserve(element));
  }, []);

  // 模拟数据：英雄区图片
  const heroImages = [
    { id: 1, src: "/maiganhua/long1.jpg", alt: "龙腾盛世麦秆画" },
    { id: 2, src: "/maiganhua/f1.jpg", alt: "花开富贵麦秆画" },
    { id: 3, src: "/maiganhua/ma1.jpg", alt: "马到成功麦秆画" },
    { id: 4, src: "/maiganhua/hu.jpg", alt: "虎虎生威麦秆画" }
  ];

  if (loading) {
    return (
      <div className="fixed inset-0 flex items-center justify-center bg-[#f9f6f0] z-50">
        <div className="text-center">
          <div className="w-24 h-24 border-4 border-[#d4af37] border-t-transparent rounded-full animate-spin mx-auto mb-4"></div>
          <p className="text-[#3a0c0c] text-lg font-semibold">正在加载...</p>
