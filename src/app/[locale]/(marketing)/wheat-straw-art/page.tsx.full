              {wheatStrawArtworks.map((artwork, index) => (
                <motion.div
                  key={artwork.id}
                  initial={{ opacity: 0, y: 20 }}
                  animate={{ opacity: 1, y: 0 }}
                  transition={{ delay: index * 0.2 }}
                  className="bg-white rounded-lg shadow-lg overflow-hidden hover:shadow-xl transition-shadow duration-300"
                  onClick={() => handleArtworkClick(artwork)}
                >
                  <div className="relative h-64 overflow-hidden">
                    <motion.img
                      src={artwork.images[0].src}
                      alt={artwork.title}
                      className="w-full h-full object-cover"
                      whileHover={{ scale: 1.05 }}
                      transition={{ duration: 0.3 }}
                    />
                    <div className="absolute inset-0 bg-gradient-to-t from-black/60 to-transparent opacity-0 hover:opacity-100 transition-opacity duration-300 flex items-end">
                      <div className="p-4 text-white">
                        <h3 className="text-xl font-bold">{artwork.title}</h3>
                        <p className="text-lg">{artwork.price} 元</p>
                      </div>
                    </div>
                  </div>
                  <div className="p-4">
                    <h3 className="text-xl font-bold text-[#3a0c0c] mb-2">{artwork.title}</h3>
                    <p className="text-gray-600 mb-4 line-clamp-2">{artwork.description}</p>
                    <div className="flex justify-between items-center">
                      <span className="text-xl font-bold text-[#d4af37]">{artwork.price} 元</span>
                      <button
                        className="bg-[#3a0c0c] text-white px-4 py-2 rounded hover:bg-[#5a1c1c] transition-colors duration-300"
                        onClick={(e) => {
                          e.stopPropagation();
                          handleAddToCart();
                        }}
                      >
                        加入购物车
                      </button>
                    </div>
                  </div>
                </motion.div>
              ))}
            </div>
          </div>

          {/* 主要内容区 - 图片展示 */}
          <div className="mb-20">
            <div className="grid grid-cols-1 md:grid-cols-2 gap-8">
              <div className="bg-white rounded-lg shadow-lg overflow-hidden">
                <div className="relative">
